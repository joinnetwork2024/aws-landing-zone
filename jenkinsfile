stage('Debug PATH and Terraform') {
    steps {
        sh '''
            echo "Current working directory:"
            pwd
            echo ""
            echo "PATH is:"
            echo $PATH
            echo ""
            which terraform || echo "terraform NOT found in PATH"
            terraform --version || echo "terraform command failed"
            ls -la /usr/local/bin/terraform || echo "Not in /usr/local/bin"
            ls -la ~/bin/terraform || echo "Not in ~/bin"
        '''
    }
}