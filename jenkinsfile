pipeline {
    // This runs the entire pipeline inside a Docker container with Terraform pre-installed
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Terraform Init') {
            steps {
                dir('environments/dev/flashsale') {
                    sh 'terraform init'
                    // Optional: add -upgrade if you want to force provider/module updates
                    // sh 'terraform init -upgrade'
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                dir('environments/dev/flashsale') {
                    sh 'terraform validate'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir('environments/dev/flashsale') {
                    sh 'terraform plan -out=tfplan'
                    // Optional: save the plan artifact for review/apply later
                    // archiveArtifacts artifacts: 'environments/dev/flashsale/tfplan', fingerprint: true
                }
            }
        }

        // Example: Add Apply stage later with manual approval
        /*
        stage('Approval') {
            steps {
                input message: 'Apply Terraform changes?', ok: 'Apply'
            }
        }

        stage('Terraform Apply') {
            steps {
                dir('environments/dev/flashsale') {
                    sh 'terraform apply -auto-approve tfplan'
                }
            }
        }
        */
    }

    // Optional: Clean up workspace after run
    post {
        always {
            cleanWs()
        }
    }
}