pipeline {
    agent {
        docker {
            image 'hashicorp/terraform:1.14.6'  // pin to avoid surprises
            // args '-u root:root'  // uncomment if you get permission errors on workspace files
        }
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Terraform Init') {
            steps {
                dir('environments/dev/flashsale') {
                    sh 'terraform init'
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                dir('environments/dev/flashsale') {
                    sh 'terraform validate'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir('environments/dev/flashsale') {
                    sh 'terraform plan -out=tfplan'
                }
            }
        }
    }

    post {
        always {
            cleanWs()  // optional: cleanup
        }
    }
}